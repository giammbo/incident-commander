# Generate secrets:
#   FERNET_KEYS: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   SESSION_SECRET: python -c "import secrets; print(secrets.token_urlsafe(48))"
POSTGRES_USER=ic
POSTGRES_PASSWORD=change-me
POSTGRES_DB=incident_commander
SESSION_SECRET=
FERNET_KEYS=
BASE_URL=http://localhost:8000
IC_ADMIN_EMAIL=admin@localhost
# Session cookie Secure flag. Set to true (the default in code) in production behind HTTPS;
# false here so the out-of-box localhost docker experience works over plain HTTP.
SESSION_HTTPS_ONLY=false
